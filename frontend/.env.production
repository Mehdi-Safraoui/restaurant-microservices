# ============================================
# Production Environment Variables
# ============================================
# In production, the frontend is served behind the API gateway or a reverse proxy.
# All API calls go through the gateway directly.

VITE_API_GATEWAY_URL=http://localhost:8077

VITE_USERS_API_URL=http://localhost:8077/api/users
VITE_PLATS_API_URL=http://localhost:8077/api/plats
VITE_INGREDIENTS_API_URL=http://localhost:8077/api/ingredients
VITE_COMMANDES_API_URL=http://localhost:8077/api/commandes
VITE_REVIEWS_API_URL=http://localhost:8077/api/reviews
VITE_COMPLAINTS_API_URL=http://localhost:8077/api/complaints
VITE_DELIVERIES_API_URL=http://localhost:8077/api/deliveries
VITE_EVENTS_API_URL=http://localhost:8077/api/events
VITE_BLOGS_API_URL=http://localhost:8077/api/blogs

VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=Delivery_Board_Realm
